# pixi-live2d-display@0.4.0 declares peer @pixi/core@^6 but the rest of
# the app uses pixi.js@^7. They co-exist fine at runtime — the live2d
# display lib works against pixi 7's drop-in compatibility layer — but
# npm's strict peer-dep resolver refuses to install without this.
# Required for `npm install` and `npm ci` (CI) to succeed.
legacy-peer-deps=true
